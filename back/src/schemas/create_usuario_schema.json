{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CreateUsuarioSchema",
  "type": "object",
  "properties": {
    "user": {
        "type": "string"
    },
    "email": {
        "type": "string",
        "format": "email"
    },
    "password": {
        "type": "string",
        "minimum": 6
    },
    "is_admin": {
        "type": "boolean"
    }
  },
  "required": ["user",
    "email",
    "password",
    "is_admin"
  ]
}