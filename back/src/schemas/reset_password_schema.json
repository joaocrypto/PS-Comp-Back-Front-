{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AuthSchema",
  "type": "object",
  "properties": {
    "email": {
        "type": "string",
        "format": "email"
    },
    "password": {
        "type": "string",
        "minimum": 6
    },
    "codigo": {
        "type": "string"
    }
  },
  "required": [
    "email",
    "password",
    "codigo"
  ]
}